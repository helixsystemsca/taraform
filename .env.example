# Server-only: never prefix with NEXT_PUBLIC_. Set the same name in Vercel → Environment Variables.
OPENAI_API_KEY=your_key_here

# Supabase
# - Server code uses SUPABASE_URL / SUPABASE_ANON_KEY
# - Browser code uses NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public URL — used for magic-link / email confirmation redirects when set.
# Include the scheme (https:// or http:// for localhost). Host-only values are auto-fixed, but prefer full URLs.
# Add the same origin + `/auth/callback` (and `/taraform/auth/callback` if you use basePath) in Supabase → Authentication → Redirect URLs.
# For local dev, leave unset so links use the request host/port, OR set e.g. http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://your-domain.example
# Optional server override (origin only, with scheme):
# AUTH_REDIRECT_ORIGIN=https://your-domain.example

# App is private (allowlisted emails). Leave blank to disable allowlist.
# Comma-separated.
ALLOWED_EMAILS=taradcollins@icloud.com,josh.collins@helixsystems.ca

# Optional in local dev only: allows DB/storage without a Supabase Auth session when NODE_ENV=development.
# See `lib/auth/devUser.ts` + `getCurrentUser()` / `getServerSupabase()`. Never set on production Vercel.
# SUPABASE_SERVICE_ROLE_KEY=

# App URL prefix is set in next.config.ts (`basePath: "/taraform"`).
# NEXT_PUBLIC_BASE_PATH is injected there for client-side public URLs.

# Canonical site URL for metadata (optional). Host-only is OK — https:// is added automatically.
# NEXT_PUBLIC_SITE_URL=https://taraform.helixsystems.ca

# FastAPI study backend (see `backend/README.md`). No trailing slash. Local: http://127.0.0.1:8000
# NEXT_PUBLIC_STUDY_API_URL=http://127.0.0.1:8000

