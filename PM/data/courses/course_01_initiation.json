{
  "course_id": "apmc_500v",
  "title": "Project Initiation & Charter Development",
  "domain": "Initiation",
  "modules": [
    {
      "title": "Terminology & Foundations",
      "concepts": [
        {
          "id": "init_001",
          "title": "Project vs Operations",
          "definition": "A project is a temporary endeavor that creates a unique result, while operations are ongoing activities that sustain the business.",
          "key_points": [
            "Projects have defined start and end dates",
            "Operations are repetitive and continuous",
            "Projects introduce change"
          ],
          "why_it_matters": "Many PMP questions test whether work is project-based or operational.",
          "example": "Building a facility is a project; maintaining it is operations.",
          "exam_trap": "Not all deadline-driven work is a project."
        },
        {
          "id": "init_002",
          "title": "Program vs Portfolio",
          "definition": "Programs group related projects for shared benefits; portfolios align projects with strategic objectives.",
          "key_points": [
            "Programs deliver combined value",
            "Portfolios focus on strategy alignment"
          ],
          "why_it_matters": "Helps understand decision-making at organizational level.",
          "example": "Multiple facility upgrades = program.",
          "exam_trap": "Programs are not just large projects."
        },
        {
          "id": "init_003",
          "title": "Deliverables & Milestones",
          "definition": "Deliverables are outputs; milestones are key checkpoints.",
          "key_points": [
            "Deliverables must be verifiable",
            "Milestones track progress"
          ],
          "why_it_matters": "Critical for planning and tracking.",
          "example": "Completed blueprint = deliverable; approval date = milestone.",
          "exam_trap": "Milestones are not work tasks."
        },
        {
          "id": "init_004",
          "title": "Scope Creep",
          "definition": "Uncontrolled expansion of scope without adjustments to time or cost.",
          "key_points": [
            "Occurs without change control",
            "Leads to delays and overruns"
          ],
          "why_it_matters": "One of the most common failure causes.",
          "example": "Adding features without approval.",
          "exam_trap": "Approved changes are not scope creep."
        },
        {
          "id": "init_005",
          "title": "Work Breakdown Structure (WBS)",
          "definition": "A hierarchical decomposition of total project scope.",
          "key_points": [
            "Breaks work into manageable parts",
            "Foundation for planning"
          ],
          "why_it_matters": "Everything builds from scope clarity.",
          "example": "Breaking a build into phases and tasks.",
          "exam_trap": "WBS is not a schedule."
        }
      ]
    },

    {
      "title": "Lifecycle & Approach",
      "concepts": [
        {
          "id": "init_010",
          "title": "Project Lifecycle",
          "definition": "The phases a project goes through from start to finish.",
          "key_points": [
            "Initiation → Planning → Execution → Monitoring → Closing"
          ],
          "why_it_matters": "Defines sequence of work.",
          "example": "You must initiate before planning.",
          "exam_trap": "Phases vary by organization."
        },
        {
          "id": "init_011",
          "title": "Predictive vs Agile vs Hybrid",
          "definition": "Different approaches to managing project work.",
          "key_points": [
            "Predictive = fixed scope",
            "Agile = evolving scope",
            "Hybrid = mix"
          ],
          "why_it_matters": "Approach selection is scenario-tested.",
          "example": "Construction = predictive.",
          "exam_trap": "Agile is not always better."
        },
        {
          "id": "init_012",
          "title": "Tailoring",
          "definition": "Adapting processes to fit the project environment.",
          "key_points": [
            "No one-size-fits-all approach"
          ],
          "why_it_matters": "Core PMP principle.",
          "example": "Using agile for uncertain projects.",
          "exam_trap": "Blindly following templates."
        }
      ]
    },

    {
      "title": "Initiation",
      "concepts": [
        {
          "id": "init_020",
          "title": "Project Initiation Purpose",
          "definition": "Formal authorization of a project.",
          "key_points": [
            "Defines high-level scope",
            "Aligns with strategy"
          ],
          "why_it_matters": "Prevents premature execution.",
          "example": "Approval required before work begins.",
          "exam_trap": "Planning ≠ initiation."
        },
        {
          "id": "init_021",
          "title": "Business Case",
          "definition": "Justifies project value and need.",
          "key_points": [
            "Defines problem and benefits"
          ],
          "why_it_matters": "Projects must deliver value.",
          "example": "Reducing costs.",
          "exam_trap": "Charter does not replace business case."
        },
        {
          "id": "init_022",
          "title": "Stakeholder Register",
          "definition": "Document listing stakeholders and key info.",
          "key_points": [
            "Includes influence and interest"
          ],
          "why_it_matters": "Foundation for stakeholder management.",
          "example": "List of supervisors and clients.",
          "exam_trap": "Stakeholders are not static."
        }
      ]
    },

    {
      "title": "Knowledge Areas",
      "concepts": [
        { "id": "init_030", "title": "Integration", "definition": "Coordinates all aspects.", "key_points": ["Central control"], "why_it_matters": "Ensures alignment.", "example": "Managing trade-offs.", "exam_trap": "Not a phase." },
        { "id": "init_031", "title": "Scope", "definition": "Defines work included.", "key_points": ["Controls scope creep"], "why_it_matters": "Defines boundaries.", "example": "Scope statement.", "exam_trap": "Includes exclusions." },
        { "id": "init_032", "title": "Schedule", "definition": "Manages timeline.", "key_points": ["Critical path"], "why_it_matters": "Ensures deadlines.", "example": "Gantt chart.", "exam_trap": "Not just dates." },
        { "id": "init_033", "title": "Cost", "definition": "Manages budget.", "key_points": ["Estimation"], "why_it_matters": "Controls spending.", "example": "Budget tracking.", "exam_trap": "Cost ≠ value." },
        { "id": "init_034", "title": "Quality", "definition": "Ensures requirements met.", "key_points": ["Prevention over inspection"], "why_it_matters": "Customer satisfaction.", "example": "QA checks.", "exam_trap": "Testing alone is insufficient." }
      ]
    },

    {
      "title": "Stakeholders & Organization",
      "concepts": [
        {
          "id": "init_040",
          "title": "Stakeholder Analysis",
          "definition": "Evaluating stakeholder influence and interest.",
          "key_points": [
            "Power/interest grid"
          ],
          "why_it_matters": "Guides engagement strategy.",
          "example": "High power = manage closely.",
          "exam_trap": "Ignoring low power stakeholders."
        },
        {
          "id": "init_041",
          "title": "Organizational Structures",
          "definition": "Defines authority distribution.",
          "key_points": [
            "Functional, matrix, projectized"
          ],
          "why_it_matters": "Affects PM authority.",
          "example": "Matrix limits control.",
          "exam_trap": "Authority varies widely."
        }
      ]
    },

    {
      "title": "Requirements & Objectives",
      "concepts": [
        {
          "id": "init_050",
          "title": "Requirements",
          "definition": "Conditions needed to satisfy stakeholders.",
          "key_points": [
            "Must be clear and measurable"
          ],
          "why_it_matters": "Prevents rework.",
          "example": "Functional specs.",
          "exam_trap": "Vague requirements fail."
        },
        {
          "id": "init_051",
          "title": "SMART Objectives",
          "definition": "Clear measurable project goals.",
          "key_points": [
            "Specific, measurable, achievable, relevant, time-bound"
          ],
          "why_it_matters": "Defines success.",
          "example": "Reduce costs by 10%.",
          "exam_trap": "Goals ≠ objectives."
        }
      ]
    },

    {
      "title": "Selection, Constraints & Charter",
      "concepts": [
        {
          "id": "init_060",
          "title": "Selection Methods",
          "definition": "Evaluating project viability.",
          "key_points": [
            "NPV, IRR, Payback"
          ],
          "why_it_matters": "Ensures value.",
          "example": "Choosing highest ROI.",
          "exam_trap": "ROI alone isn’t enough."
        },
        {
          "id": "init_061",
          "title": "Constraints & Assumptions",
          "definition": "Limits and accepted conditions.",
          "key_points": [
            "Assumptions create risk"
          ],
          "why_it_matters": "Impacts planning.",
          "example": "Assuming resource availability.",
          "exam_trap": "Assumptions are not facts."
        },
        {
          "id": "init_062",
          "title": "Project Charter",
          "definition": "Document that authorizes the project.",
          "key_points": [
            "Grants PM authority"
          ],
          "why_it_matters": "Essential for project start.",
          "example": "Signed by sponsor.",
          "exam_trap": "Not a detailed plan."
        }
      ]
    }
  ]
}